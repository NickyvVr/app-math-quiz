<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MathQuiz" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/dark_gray</item>
        <item name="colorAccent">@color/accent_orange</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:windowBackground">@color/light_gray</item>
    </style>

    <style name="ButtonStyle" parent="Widget.AppCompat.Button.Colored">
        <item name="android:textSize">18sp</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="LevelButton" parent="">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="NumberPadButton" parent="">
        <item name="android:background">@drawable/number_pad_button</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="QuestionText" parent="">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/primary_green</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="StreakText" parent="">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/accent_orange</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
